rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Base rule - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // User profile access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Receipts subcollection
      match /receipts/{receiptId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        
        // Validation for receipt structure
        function isValidReceipt() {
          let data = request.resource.data;
          
          // Require metadata
          return data.keys().hasAll(['metadata']) && 
            
            // Metadata validation
            data.metadata is map && 
            data.metadata.keys().hasAll(['created_at', 'updated_at', 'status']) &&
            (data.metadata.status == 'draft' || data.metadata.status == 'completed') &&
            
            // If receipt is completed, ensure it has a restaurant name
            (data.metadata.status == 'draft' || 
             (data.metadata.status == 'completed' && 
              data.metadata.keys().hasAny(['restaurant_name']) && 
              data.metadata.restaurant_name is string && 
              data.metadata.restaurant_name.size() > 0));
        }
        
        // Require valid structure on create
        allow create: if request.auth != null && 
                        request.auth.uid == userId && 
                        isValidReceipt();
        
        // Allow updates with valid structure
        allow update: if request.auth != null && 
                        request.auth.uid == userId && 
                        isValidReceipt();
      }
    }
    
    // Existing top-level receipts collection
    match /receipts/{receiptId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }
  }
}